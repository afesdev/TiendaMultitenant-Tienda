---
interface Props {
	id: number;
	nombre: string;
	precio: number;
	imagen: string;
	categoria?: string;
    descripcion?: string;
    tallas?: string;
    colores?: string;
	/** Precio original (tachado) cuando hay oferta */
	precioOriginal?: number;
	/** Indica si el producto tiene oferta activa */
	tieneOferta?: boolean;
}

const { id, nombre, precio, imagen, categoria, descripcion, tallas, colores, precioOriginal, tieneOferta } = Astro.props;

const formatPrice = (p: number) => {
    return new Intl.NumberFormat('es-CO', {
        style: 'currency',
        currency: 'COP',
        maximumFractionDigits: 0
    }).format(p);
};

const tallasArray = tallas ? tallas.split(',') : [];
const coloresArray = colores ? colores.split(',') : [];
---

<div class="product-card group relative flex flex-col h-full bg-white transition-all cursor-pointer border border-gray-50 hover:shadow-2xl" data-id={id}>
    <div class="relative overflow-hidden bg-gray-50 aspect-[2/3]">
        <img 
            src={imagen || 'https://via.placeholder.com/600x900?text=Sin+Imagen'} 
            alt={nombre}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
        />
        {categoria && (
            <span class="absolute top-3 left-3 bg-white/95 backdrop-blur-md text-gray-900 text-[9px] font-bold uppercase tracking-[2px] px-3 py-1.5 rounded shadow-sm">
                {categoria}
            </span>
        )}
        
        <!-- Botón rápido Agregar al Carrito (Aparece en hover) -->
        <div class="absolute inset-x-0 bottom-0 p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
            <button class="w-full bg-gray-900/90 backdrop-blur text-white text-[10px] font-black uppercase tracking-[2px] py-3 rounded-xl shadow-lg">
                Ver Opciones
            </button>
        </div>
    </div>
    
    <div class="p-5 lg:p-8 flex flex-col flex-grow text-center">
        <h3 class="text-sm lg:text-base font-bold text-gray-900 uppercase tracking-widest mb-2 line-clamp-1 group-hover:text-primario transition-colors">
            {nombre}
        </h3>
        
        <div class="mt-auto">
            <p class="text-lg lg:text-xl font-black text-gray-900 mb-4">
                {tieneOferta && precioOriginal != null ? (
                    <span>
                        <span class="line-through text-gray-400 font-semibold mr-2">{formatPrice(precioOriginal)}</span>
                        <span class="text-primario">{formatPrice(precio)}</span>
                    </span>
                ) : (
                    formatPrice(precio)
                )}
            </p>

            <div class="flex flex-col gap-3 border-t border-gray-100 pt-5">
                <!-- Colores del producto -->
                {coloresArray.length > 0 && (
                    <div class="flex flex-wrap gap-1.5 justify-center items-center">
                        {coloresArray.map(c => (
                            <div class="flex flex-col items-center gap-1">
                                <span class="text-[8px] font-bold text-gray-400 uppercase tracking-tighter line-clamp-1 max-w-[50px]">{c}</span>
                                <div class="w-3 h-3 rounded-full border border-gray-200 bg-gray-100 shadow-inner"></div>
                            </div>
                        ))}
                    </div>
                )}
                
                <!-- Tallas -->
                {tallasArray.length > 0 && (
                    <div class="flex flex-wrap gap-1 justify-center">
                        {tallasArray.map(t => (
                            <span class="text-[9px] font-bold text-gray-400 bg-gray-50 border border-gray-100 px-1.5 py-0.5 rounded uppercase">{t}</span>
                        ))}
                    </div>
                )}
            </div>
        </div>
    </div>
</div>
