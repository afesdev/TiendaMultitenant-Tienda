---
interface Props {
    tiendaInfo?: {
        NombreComercial?: string;
        Configuracion?: {
            direccion?: string;
            telefono?: string;
            horarios?: string;
            social?: {
                facebook?: string;
                instagram?: string;
                whatsapp?: string;
                tiktok?: string;
            };
        };
    };
}
const { tiendaInfo = {} } = Astro.props;
const year = new Date().getFullYear();
const nombre = tiendaInfo.NombreComercial || 'Tienda';
const cfg = tiendaInfo.Configuracion || {};
const direccion = cfg.direccion;
const telefono = cfg.telefono;
const horarios = cfg.horarios;
const social = cfg.social || {};
const hasContact = direccion || telefono || horarios;
const hasSocial = social.facebook || social.instagram || social.whatsapp || social.tiktok;
---

<footer class="bg-white border-t border-gray-100 py-10 mt-10">
    <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center md:text-left">
            <div>
                <p class="text-sm font-bold text-gray-900 mb-2">{nombre}</p>
                {(hasContact) && (
                    <div class="space-y-1 text-xs text-gray-500">
                        {direccion && <p class="flex items-center justify-center md:justify-start gap-1.5"><i class="bi bi-geo-alt"></i> {direccion}</p>}
                        {telefono && <p class="flex items-center justify-center md:justify-start gap-1.5"><i class="bi bi-telephone"></i> <a href={`tel:${telefono.replace(/\s/g, '')}`} class="hover:text-gray-900">{telefono}</a></p>}
                        {horarios && <p class="flex items-center justify-center md:justify-start gap-1.5"><i class="bi bi-clock"></i> {horarios}</p>}
                    </div>
                )}
            </div>
            <div class="flex flex-col items-center md:items-start">
                {hasSocial && (
                    <>
                        <p class="text-xs font-semibold text-gray-700 mb-2 uppercase tracking-wider">Síguenos</p>
                        <div class="flex gap-3">
                            {social.facebook && <a href={social.facebook} target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-gray-900 transition-colors" aria-label="Facebook"><i class="bi bi-facebook text-lg"></i></a>}
                            {social.instagram && <a href={social.instagram} target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-gray-900 transition-colors" aria-label="Instagram"><i class="bi bi-instagram text-lg"></i></a>}
                            {social.whatsapp && <a href={social.whatsapp} target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-gray-900 transition-colors" aria-label="WhatsApp"><i class="bi bi-whatsapp text-lg"></i></a>}
                            {social.tiktok && <a href={social.tiktok} target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-gray-900 transition-colors" aria-label="TikTok"><i class="bi bi-tiktok text-lg"></i></a>}
                        </div>
                    </>
                )}
            </div>
            <div class="flex flex-col items-center md:items-end justify-center">
                <p class="text-xs text-gray-500 mb-1">© {year} {nombre}. Todos los derechos reservados.</p>
                <p class="text-xs text-gray-400">
                    Desarrollado por <a href="https://www.instagram.com/amei_group/" target="_blank" class="text-primario hover:underline font-medium">amei_group</a>
                </p>
            </div>
        </div>
    </div>
</footer>
