---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import ProductCard from '../../components/ProductCard.astro';
import Footer from '../../components/Footer.astro';
import { SITE_CONFIG } from '../../config';

const { API_BASE, TIENDA_SLUG } = SITE_CONFIG;

export async function getStaticPaths() {
    const { API_BASE, TIENDA_SLUG } = SITE_CONFIG;
    try {
        const res = await fetch(`${API_BASE}/tiendas/${TIENDA_SLUG}/categorias`);
        if (!res.ok) return [];
        const categorias = await res.json();
        return categorias.map((cat: { Slug: string }) => ({ params: { slug: cat.Slug } }));
    } catch {
        return [];
    }
}

const { slug } = Astro.params;

let tiendaInfo = { NombreComercial: 'Cargando...' };
let categorias = [];
let productos = [];
let error = null;

try {
    const [tiendaRes, catRes] = await Promise.all([
        fetch(`${API_BASE}/tiendas/${TIENDA_SLUG}`),
        fetch(`${API_BASE}/tiendas/${TIENDA_SLUG}/categorias`)
    ]);

    if (tiendaRes.ok) tiendaInfo = await tiendaRes.json();
    if (catRes.ok) categorias = await catRes.json();

    const prodRes = await fetch(`${API_BASE}/tiendas/${TIENDA_SLUG}/productos?categoria=${slug}`);
    if (prodRes.ok) productos = await prodRes.json();
} catch (e) {
    error = "Error de conexión.";
}

const categoriaActual = categorias.find(c => c.Slug === slug);
---

<Layout title={`${categoriaActual?.Nombre || 'Categoría'} - ${tiendaInfo.NombreComercial}`}>
	<Navbar tiendaNombre={tiendaInfo.NombreComercial} categorias={categorias} />
	
	<main class="w-full flex-grow pb-32 lg:pb-12">
        <div class="px-6 lg:px-12 py-10 lg:py-16">
            <span class="text-[10px] font-black text-primario uppercase tracking-[4px] mb-2 block text-center lg:text-left">Categoría</span>
            <h1 class="text-4xl lg:text-6xl font-black text-gray-900 uppercase tracking-tighter text-center lg:text-left">{categoriaActual?.Nombre || 'Explorar'}</h1>
        </div>

        {productos.length === 0 ? (
            <div class="py-20 text-center opacity-30">
                <i class="bi bi-bag-x text-6xl mb-4 block"></i>
                <p class="text-xs font-black uppercase tracking-[3px]">No hay productos en esta categoría</p>
            </div>
        ) : (
        <div class="px-px lg:px-6 w-full">
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-px lg:gap-6 bg-gray-100 lg:bg-transparent">
                {productos.map((prod) => (
                    <ProductCard 
                        id={prod.Id}
                        nombre={prod.Nombre}
                        precio={prod.TieneOferta && prod.PrecioOferta != null ? prod.PrecioOferta : prod.PrecioDetal}
                        imagen={prod.ImagenPrincipal}
                        categoria={prod.CategoriaNombre}
                        descripcion={prod.Descripcion}
                        tallas={prod.Tallas}
                        colores={prod.Colores}
                        precioOriginal={prod.TieneOferta ? prod.PrecioDetal : undefined}
                        tieneOferta={prod.TieneOferta}
                    />
                ))}
            </div>
        </div>
        )}
	</main>

	<Footer tiendaInfo={tiendaInfo} />

    <!-- MODAL DE PRODUCTO (VISTA COMPLETA) -->
    <div id="productModalOverlay" class="fixed inset-0 bg-white z-[300] hidden transition-opacity duration-300 opacity-0 overflow-y-auto">
        <div id="productModal" class="w-full min-h-full bg-white relative translate-y-10 transition-transform duration-500 ease-out">
            <button id="btnCloseModal" class="fixed top-6 right-6 z-[310] w-12 h-12 bg-gray-100/80 backdrop-blur-md hover:bg-gray-200 rounded-full flex items-center justify-center shadow-sm transition-all">
                <i class="bi bi-x-lg text-lg"></i>
            </button>
            <div id="modalContent" class="w-full">
                <!-- Inyectado por JS -->
            </div>
        </div>
    </div>

    <!-- CARRITO LATERAL -->
    <div id="cartOverlay" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-[400] hidden transition-opacity duration-300 opacity-0"></div>
    <div id="cartOffcanvas" class="fixed top-0 right-0 h-full w-full max-w-[450px] bg-white z-[401] translate-x-full transition-transform duration-300 ease-in-out shadow-2xl flex flex-col">
        <div class="px-8 py-8 border-b border-gray-50 flex items-center justify-between bg-white">
            <h5 class="font-black text-xs uppercase tracking-[4px]">Mi Bolsa</h5>
            <button id="btnCloseCart" class="p-2 text-gray-400 hover:text-gray-900 transition-colors">
                <i class="bi bi-x-lg text-lg"></i>
            </button>
        </div>
        <div id="cartItems" class="flex-grow overflow-y-auto px-6 py-6 bg-gray-50/30">
            <!-- Items -->
        </div>
        <div id="cartFooter" class="p-8 bg-white border-t border-gray-100 hidden">
            <div class="flex justify-between items-center mb-8">
                <div class="flex flex-col">
                    <span class="text-[10px] font-black uppercase tracking-[3px] text-gray-400">Total Bolsa</span>
                    <span id="cart-item-count" class="text-[9px] font-bold text-primario uppercase">0 productos</span>
                </div>
                <span id="cartTotal" class="text-2xl font-black text-gray-900 tracking-tighter">$0</span>
            </div>
            <button id="btnCheckout" class="w-full bg-gray-900 hover:bg-black text-white text-[11px] font-black uppercase tracking-[4px] py-6 rounded-[2rem] shadow-xl transition-all">
                Finalizar Pedido
            </button>
        </div>
    </div>

    <!-- MODAL DE CHECKOUT -->
    <div id="checkoutModalOverlay" class="fixed inset-0 bg-black/60 backdrop-blur-md z-[500] hidden flex items-center justify-center p-4 transition-opacity duration-300 opacity-0">
        <div id="checkoutModal" class="bg-white w-full max-w-xl rounded-[2.5rem] overflow-hidden shadow-2xl relative translate-y-10 transition-transform duration-300">
            <div class="p-8 lg:p-12">
                <div class="flex justify-between items-center mb-8">
                    <h2 class="text-2xl font-black text-gray-900 uppercase tracking-tighter">Datos de Envío</h2>
                    <button id="btnCloseCheckout" class="text-gray-400 hover:text-gray-900"><i class="bi bi-x-lg text-xl"></i></button>
                </div>
                
                <form id="checkoutForm" class="space-y-4">
                    <div class="grid grid-cols-2 gap-4">
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[10px] font-black uppercase tracking-widest text-gray-400 ml-2">Cédula</label>
                            <input type="text" name="cedula" required class="bg-gray-50 border-0 rounded-2xl py-4 px-6 text-xs font-bold focus:ring-2 focus:ring-primario/20 outline-none" placeholder="123456789" />
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[10px] font-black uppercase tracking-widest text-gray-400 ml-2">WhatsApp</label>
                            <input type="tel" name="celular" required class="bg-gray-50 border-0 rounded-2xl py-4 px-6 text-xs font-bold focus:ring-2 focus:ring-primario/20 outline-none" placeholder="300 123 4567" />
                        </div>
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label class="text-[10px] font-black uppercase tracking-widest text-gray-400 ml-2">Nombre Completo</label>
                        <input type="text" name="nombre" required class="bg-gray-50 border-0 rounded-2xl py-4 px-6 text-xs font-bold focus:ring-2 focus:ring-primario/20 outline-none" placeholder="Ej: Juan Pérez" />
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[10px] font-black uppercase tracking-widest text-gray-400 ml-2">Ciudad</label>
                            <input type="text" name="ciudad" required class="bg-gray-50 border-0 rounded-2xl py-4 px-6 text-xs font-bold focus:ring-2 focus:ring-primario/20 outline-none" placeholder="Ej: Medellín" />
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[10px] font-black uppercase tracking-widest text-gray-400 ml-2">Método de Pago</label>
                            <select name="metodoPago" required class="bg-gray-50 border-0 rounded-2xl py-4 px-6 text-xs font-bold focus:ring-2 focus:ring-primario/20 outline-none appearance-none cursor-pointer">
                                <option value="Efectivo">Efectivo (Contra entrega)</option>
                                <option value="Transferencia">Transferencia Bancaria</option>
                            </select>
                        </div>
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label class="text-[10px] font-black uppercase tracking-widest text-gray-400 ml-2">Dirección Completa</label>
                        <input type="text" name="direccion" required class="bg-gray-50 border-0 rounded-2xl py-4 px-6 text-xs font-bold focus:ring-2 focus:ring-primario/20 outline-none" placeholder="Calle 123 #45-67 Barrio ..." />
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label class="text-[10px] font-black uppercase tracking-widest text-gray-400 ml-2">Observación (Opcional)</label>
                        <textarea name="observacion" class="bg-gray-50 border-0 rounded-2xl py-4 px-6 text-xs font-bold focus:ring-2 focus:ring-primario/20 outline-none resize-none" rows="2" placeholder="Ej: Portería, dejar con el vecino..."></textarea>
                    </div>

                    <button type="submit" id="btnSubmitOrder" class="w-full bg-gray-900 hover:bg-black text-white text-[11px] font-black uppercase tracking-[4px] py-6 rounded-[2rem] shadow-xl transition-all mt-4 flex items-center justify-center gap-3">
                        <span>Confirmar Mi Pedido</span>
                        <i class="bi bi-arrow-right"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- MODAL ÉXITO -->
    <div id="successModalOverlay" class="fixed inset-0 bg-white z-[600] hidden flex items-center justify-center p-4">
        <div class="text-center max-w-md mx-auto">
            <div class="w-24 h-24 bg-green-50 text-green-500 rounded-full flex items-center justify-center mx-auto mb-8 shadow-inner">
                <i class="bi bi-check-lg text-5xl"></i>
            </div>
            <h2 class="text-4xl font-black text-gray-900 uppercase tracking-tighter mb-4">¡Pedido Recibido!</h2>
            <p class="text-[11px] font-bold text-gray-400 uppercase tracking-widest leading-loose mb-10">Gracias por tu compra. Nos pondremos en contacto contigo vía WhatsApp para coordinar la entrega.</p>
            <button onclick="location.reload()" class="bg-gray-900 text-white text-[10px] font-black uppercase tracking-[3px] px-12 py-5 rounded-2xl hover:bg-black transition-all shadow-xl">
                Volver a la Tienda
            </button>
        </div>
    </div>

    <!-- OVERLAY IMAGEN AMPLIADA -->
    <div id="imageFullscreenOverlay" class="fixed inset-0 bg-black/90 z-[700] hidden flex items-center justify-center p-4">
        <button id="btnCloseImageFullscreen" class="absolute top-6 right-6 w-10 h-10 rounded-full bg-black/60 hover:bg-black text-white flex items-center justify-center shadow-lg">
            <i class="bi bi-x-lg text-base"></i>
        </button>
        <img
            id="imageFullscreenImg"
            src=""
            alt="Vista ampliada del producto"
            class="max-h-full max-w-full object-contain rounded-2xl shadow-2xl"
        />
    </div>
</Layout>

<script>
    import { SITE_CONFIG } from '../../config';
    const { API_BASE, TIENDA_SLUG } = SITE_CONFIG;

    let cart = JSON.parse(localStorage.getItem('cart') || '[]');
    let selectedProduct = null;
    let selectedVarianteId = null;
    let selectedVariantePrecioAdicional = 0;
    let currentStock = 0;

    const modalOverlay = document.getElementById('productModalOverlay');
    const modal = document.getElementById('productModal');
    const modalContent = document.getElementById('modalContent');
    const cartOverlay = document.getElementById('cartOverlay');
    const cartOffcanvas = document.getElementById('cartOffcanvas');
    const cartItemsContainer = document.getElementById('cartItems');
    const cartFooter = document.getElementById('cartFooter');
    const cartTotal = document.getElementById('cartTotal');
    const cartItemCount = document.getElementById('cart-item-count');
    const btnCloseCart = document.getElementById('btnCloseCart');

    const btnCheckout = document.getElementById('btnCheckout');
    const checkoutModalOverlay = document.getElementById('checkoutModalOverlay');
    const checkoutModal = document.getElementById('checkoutModal');
    const btnCloseCheckout = document.getElementById('btnCloseCheckout');
    const checkoutForm = document.getElementById('checkoutForm') as HTMLFormElement;
    const successModalOverlay = document.getElementById('successModalOverlay');

    const imageFullscreenOverlay = document.getElementById('imageFullscreenOverlay');
    const btnCloseImageFullscreen = document.getElementById('btnCloseImageFullscreen');

    const toggleModal = (show) => {
        if (show) { modalOverlay.classList.remove('hidden'); setTimeout(() => { modalOverlay.classList.add('opacity-100'); modal.classList.add('translate-y-0', 'opacity-100'); }, 10); document.body.style.overflow = 'hidden'; }
        else { modalOverlay.classList.remove('opacity-100'); modal.classList.remove('translate-y-0', 'opacity-100'); setTimeout(() => { modalOverlay.classList.add('hidden'); document.body.style.overflow = ''; }, 300); }
    };

    const toggleCart = (show) => {
        if (show) { cartOverlay.classList.remove('hidden'); setTimeout(() => { cartOverlay.classList.add('opacity-100'); cartOffcanvas.classList.remove('translate-x-full'); }, 10); document.body.style.overflow = 'hidden'; }
        else { cartOverlay.classList.remove('opacity-100'); cartOffcanvas.classList.add('translate-x-full'); setTimeout(() => { cartOverlay.classList.add('hidden'); document.body.style.overflow = ''; }, 300); }
    };

    const toggleCheckout = (show) => {
        if (show) {
            checkoutModalOverlay.classList.remove('hidden');
            setTimeout(() => {
                checkoutModalOverlay.classList.add('opacity-100');
                checkoutModal.classList.add('translate-y-0');
            }, 10);
            document.body.style.overflow = 'hidden';
        } else {
            checkoutModalOverlay.classList.remove('opacity-100');
            checkoutModal.classList.remove('translate-y-0');
            setTimeout(() => {
                checkoutModalOverlay.classList.add('hidden');
                document.body.style.overflow = '';
            }, 300);
        }
    };

    const closeImageFullscreen = () => {
        if (!imageFullscreenOverlay) return;
        imageFullscreenOverlay.classList.add('hidden');
    };

    (window as any).openImageFullscreen = () => {
        const mainImg = document.getElementById('modal-main-img') as HTMLImageElement | null;
        const fullscreenImg = document.getElementById('imageFullscreenImg') as HTMLImageElement | null;
        if (!mainImg || !imageFullscreenOverlay || !fullscreenImg) return;

        fullscreenImg.src = mainImg.src;
        imageFullscreenOverlay.classList.remove('hidden');
    };

    btnCloseImageFullscreen?.addEventListener('click', closeImageFullscreen);
    imageFullscreenOverlay?.addEventListener('click', (e) => {
        if (e.target === imageFullscreenOverlay) closeImageFullscreen();
    });

    async function applyPromotionsForItems(items: any[]) {
        try {
            const resp = await fetch(`${API_BASE}/promociones/calcular`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    tiendaSlug: TIENDA_SLUG,
                    items: items.map((it) => ({
                        productoId: it.productoId,
                        varianteId: it.varianteId ?? null,
                        cantidad: it.cantidad,
                        precioBase: it.precioBase,
                    })),
                }),
            });
            if (!resp.ok) return items;
            const data = await resp.json();
            return data.map((r: any, idx: number) => ({
                ...items[idx],
                precioFinal: typeof r.precioFinal === 'number' ? r.precioFinal : items[idx].precioBase,
            }));
        } catch {
            return items;
        }
    }

    function updateCartUI() {
        localStorage.setItem('cart', JSON.stringify(cart));
        const totalItemsCount = cart.reduce((acc, item) => acc + item.cantidad, 0);
        document.querySelectorAll('.cart-badge-count').forEach(b => { b.textContent = totalItemsCount; b.classList.toggle('hidden', totalItemsCount === 0); });
        if (cart.length === 0) { cartItemsContainer.innerHTML = `<div class="h-full flex flex-col items-center justify-center opacity-20"><i class="bi bi-bag-x text-6xl mb-4"></i><p class="text-[10px] font-black uppercase tracking-[3px]">Tu bolsa está vacía</p></div>`; cartFooter.classList.add('hidden'); }
        else {
            let total = 0;
            cartItemsContainer.innerHTML = cart.map((item, i) => {
                total += item.precio * item.cantidad;
                const isMax = item.cantidad >= item.stockMax;
                return `<div class="flex gap-5 bg-white p-5 rounded-3xl mb-4 shadow-sm border border-gray-50 group"><img src="${item.imagen}" class="w-20 h-28 object-cover rounded-2xl bg-gray-100" /><div class="flex-grow py-1 flex flex-col"><div class="flex justify-between"><h4 class="text-[10px] font-black uppercase tracking-wider text-gray-900">${item.nombre}</h4><button onclick="removeFromCart(${i})" class="text-gray-300 hover:text-red-500 transition-colors"><i class="bi bi-trash3"></i></button></div><p class="text-[9px] font-bold text-gray-400 mt-1 uppercase tracking-widest">${item.varianteLabel || ''}</p><div class="mt-auto flex justify-between items-center"><div class="flex flex-col gap-1"><div class="flex items-center bg-gray-50 rounded-xl p-1 border border-gray-100"><button onclick="updateQty(${i}, -1)" class="w-7 h-7 flex items-center justify-center font-bold hover:text-primario transition-colors">-</button><span class="w-8 text-center text-[10px] font-black">${item.cantidad}</span><button onclick="updateQty(${i}, 1)" class="w-7 h-7 flex items-center justify-center font-bold transition-colors ${isMax ? 'text-gray-200 cursor-not-allowed' : 'hover:text-primario'}" ${isMax ? 'disabled' : ''}>+</button></div>${isMax ? `<span class="text-[7px] text-red-400 font-bold uppercase tracking-tighter">Límite de stock</span>` : ''}</div><span class="text-xs font-black text-gray-900">${new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(item.precio * item.cantidad)}</span></div></div></div>`;
            }).join('');
            cartTotal.textContent = new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(total);
            cartItemCount.textContent = `${totalItemsCount} ${totalItemsCount === 1 ? 'producto' : 'productos'}`;
            cartFooter.classList.remove('hidden');
        }
    }

    (window as any).removeFromCart = (i) => { cart.splice(i, 1); updateCartUI(); };
    (window as any).updateQty = (i, d) => { const item = cart[i]; const nextQty = item.cantidad + d; if (nextQty >= 1 && nextQty <= item.stockMax) { item.cantidad = nextQty; updateCartUI(); } };

    async function openProductModal(id) {
        modalContent.innerHTML = `<div class="flex items-center justify-center p-32"><div class="loading-spinner"></div></div>`;
        toggleModal(true);
        try {
            const res = await fetch(`${API_BASE}/productos/${id}`);
            const prod = await res.json();
            selectedProduct = prod; selectedVarianteId = null; currentStock = prod.StockActual;
            renderModal(prod);
        } catch (e) { modalContent.innerHTML = `<p class="p-20 text-center font-bold uppercase tracking-widest text-xs text-red-500">Error al cargar producto</p>`; }
    }

    function renderModal(prod) {
        const fmt = (p) => new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(p);
        const variaciones = prod.Variaciones || [];
        const hasVars = variaciones.length > 0;
        const imagenes = prod.Imagenes || [];
        const mainUrl = imagenes[0]?.Url || 'https://via.placeholder.com/600x900?text=Sin+Imagen';

        const thumbnailsHtml = imagenes.length > 1
            ? `<div class="absolute bottom-4 left-0 right-0 flex gap-2 overflow-x-auto px-4 justify-center">
                ${imagenes.map((img, i) => `
                    <img
                        src="${img.Url}"
                        onclick="selectModalImage(this, '${img.Url}')"
                        class="w-12 h-16 shrink-0 object-cover rounded-lg cursor-pointer border-2 transition-all ${i === 0 ? 'border-white shadow-lg' : 'border-transparent opacity-70 hover:opacity-100'}"
                    />
                `).join('')}
               </div>`
            : '';

        modalContent.innerHTML = `
            <div class="flex flex-col w-full min-h-screen bg-white">
                <div class="relative w-full h-[55vh] bg-gray-100">
                    <img id="modal-main-img" src="${mainUrl}" class="w-full h-full object-cover transition-opacity duration-200" />
                    <button
                        type="button"
                        onclick="openImageFullscreen()"
                        class="absolute bottom-4 right-4 z-10 w-9 h-9 bg-black/40 hover:bg-black/60 text-white rounded-full flex items-center justify-center text-xs shadow-md"
                    >
                        <i class="bi bi-arrows-fullscreen"></i>
                    </button>
                    <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent pointer-events-none"></div>
                    ${thumbnailsHtml}
                </div>

                <div class="flex-grow flex flex-col p-5 lg:p-8 justify-start gap-3 max-w-4xl mx-auto w-full overflow-y-auto text-left min-h-0" style="-webkit-overflow-scrolling: touch;">
                    <div class="flex flex-col w-full">
                        <div class="flex justify-between items-start gap-4 w-full mb-1">
                            <div>
                                <span class="text-[8px] font-black text-primario uppercase tracking-[2px]">${prod.CategoriaNombre || 'Colección'}</span>
                                <h2 class="text-lg lg:text-xl font-black text-gray-900 uppercase tracking-tighter leading-tight line-clamp-1">${prod.Nombre}</h2>
                            </div>
                            <div class="text-right shrink-0">
                                <span id="modal-price" class="text-xl lg:text-2xl font-black text-gray-900 tracking-tighter">${prod.TieneOferta && prod.PrecioOferta != null
                                    ? `<span class="line-through text-gray-400 font-semibold mr-2">${fmt(prod.PrecioDetal)}</span><span class="text-primario">${fmt(prod.PrecioOferta)}</span>`
                                    : fmt(prod.PrecioDetal)}</span>
                            </div>
                        </div>
                        <p class="text-[10px] lg:text-[11px] text-gray-400 leading-tight line-clamp-2 mb-3">${prod.Descripcion || 'Sin descripción disponible.'}</p>
                    </div>

                    <div class="w-full space-y-4">
                        ${hasVars ? `
                            <div class="flex flex-col items-start">
                                <span class="text-[7px] font-black uppercase tracking-[1px] text-gray-300 mb-1">Opciones:</span>
                                <div class="flex flex-wrap gap-1">
                                    ${variaciones.map(v => {
                                        const precioBaseVar = (prod.PrecioDetal || 0) + (v.PrecioAdicional ?? 0);
                                        const precioOfertaVar = v.TieneOferta && v.PrecioOferta != null ? v.PrecioOferta : precioBaseVar;
                                        return `
                                        <button
                                            onclick="selectVariant(${v.Id}, ${v.StockActual}, '${(v.Atributo || '').replace(/'/g, "\\'")}: ${(v.Valor || '').replace(/'/g, "\\'")}', this)"
                                            class="px-2.5 py-1 border border-gray-100 rounded-md text-[8px] font-black uppercase transition-all ${v.StockActual <= 0 ? 'opacity-30 cursor-not-allowed line-through' : 'hover:border-gray-900'}"
                                            data-precio-adicional="${v.PrecioAdicional ?? 0}"
                                            data-precio-oferta="${precioOfertaVar}"
                                            data-precio-base="${precioBaseVar}"
                                            data-tiene-oferta="${v.TieneOferta ? '1' : '0'}"
                                        >
                                            ${v.Valor}
                                            ${v.PrecioAdicional && v.PrecioAdicional !== 0
                                                ? `<span class="ml-1 text-[8px] font-normal opacity-70">(+${fmt(v.PrecioAdicional)})</span>`
                                                : ''
                                            }
                                        </button>
                                    `}).join('')}
                                </div>
                            </div>
                        ` : ''}
                        
                        <div class="flex items-center justify-between border-t border-gray-50 pt-3">
                            <div id="stock-display" class="text-[8px] font-bold uppercase tracking-widest ${prod.StockActual > 0 ? 'text-green-500' : 'text-red-400'}">
                                Stock: ${prod.StockActual} un.
                            </div>
                            <div class="flex items-center bg-gray-50 rounded-lg p-0.5">
                                <button onclick="updateModalQty(-1)" class="w-7 h-7 font-black text-xs">-</button>
                                <input type="number" id="modal-qty" value="1" class="w-7 bg-transparent text-center font-black text-[10px] outline-none" readonly />
                                <button onclick="updateModalQty(1)" class="w-7 h-7 font-black text-xs">+</button>
                            </div>
                        </div>

                        <button id="btn-add-main" onclick="addToCart()" class="w-full bg-gray-900 hover:bg-black text-white text-[9px] font-black uppercase tracking-[3px] py-3.5 rounded-xl shadow-lg transition-all flex items-center justify-center gap-2 ${prod.StockActual <= 0 ? 'opacity-50 cursor-not-allowed' : ''}" ${prod.StockActual <= 0 ? 'disabled' : ''}>
                            ${prod.StockActual > 0 ? 'Añadir a mi bolsa' : 'Agotado'}
                        </button>
                    </div>
                </div>
            </div>
        `;
    }

    (window as any).selectModalImage = (thumb, url) => {
        const mainImg = document.getElementById('modal-main-img') as HTMLImageElement;
        if (mainImg) {
            mainImg.style.opacity = '0';
            setTimeout(() => { mainImg.src = url; mainImg.style.opacity = '1'; }, 150);
        }
        thumb.parentElement.querySelectorAll('img').forEach(img => {
            img.classList.remove('border-gray-900');
            img.classList.add('border-transparent');
        });
        thumb.classList.remove('border-transparent');
        thumb.classList.add('border-gray-900');
    };

    (window as any).selectVariant = (id, stock, label, btn) => {
        btn.parentElement.querySelectorAll('button').forEach(b => b.classList.remove('bg-gray-900', 'text-white', 'border-gray-900'));
        btn.classList.add('bg-gray-900', 'text-white', 'border-gray-900');
        selectedVarianteId = id; currentStock = stock; (window as any).varianteLabel = label;

        const adicionalAttr = (btn as HTMLButtonElement).getAttribute('data-precio-adicional');
        selectedVariantePrecioAdicional = adicionalAttr ? Number(adicionalAttr) : 0;
        if (isNaN(selectedVariantePrecioAdicional)) selectedVariantePrecioAdicional = 0;

        const precioOfertaAttr = (btn as HTMLButtonElement).getAttribute('data-precio-oferta');
        const precioBaseAttr = (btn as HTMLButtonElement).getAttribute('data-precio-base');
        const tieneOfertaAttr = (btn as HTMLButtonElement).getAttribute('data-tiene-oferta');
        const precioMostrar = precioOfertaAttr ? Number(precioOfertaAttr) : (precioBaseAttr ? Number(precioBaseAttr) : 0);
        const precioBase = precioBaseAttr ? Number(precioBaseAttr) : 0;
        const tieneOferta = tieneOfertaAttr === '1';

        const priceEl = document.getElementById('modal-price') as HTMLElement | null;
        if (priceEl) {
            if (tieneOferta && precioBase > 0) {
                priceEl.innerHTML = `<span class="line-through text-gray-400 font-semibold mr-2">${fmt(precioBase)}</span><span class="text-primario">${fmt(precioMostrar)}</span>`;
            } else {
                priceEl.textContent = fmt(precioMostrar);
            }
        }

        const stockDisplay = document.getElementById('stock-display');
        stockDisplay.textContent = `Stock disponible: ${stock} unidades`;
        stockDisplay.className = `text-[10px] font-bold uppercase tracking-widest ${stock > 0 ? 'text-green-500' : 'text-red-500'}`;
        const btnAdd = document.getElementById('btn-add-main') as HTMLButtonElement;
        if (stock <= 0) { btnAdd.disabled = true; btnAdd.textContent = 'Agotado'; btnAdd.classList.add('opacity-50'); }
        else { btnAdd.disabled = false; btnAdd.textContent = 'Agregar a la bolsa'; btnAdd.classList.remove('opacity-50'); }
        (document.getElementById('modal-qty') as HTMLInputElement).value = "1";
    };

    (window as any).updateModalQty = (d) => { const i = document.getElementById('modal-qty') as HTMLInputElement; const nextVal = parseInt(i.value) + d; if (nextVal >= 1 && nextVal <= currentStock) { i.value = nextVal.toString(); } };

    (window as any).addToCart = async () => {
        const variaciones = selectedProduct.Variaciones || [];
        const hasVariantes = variaciones.length > 0;
        const algunaVarianteConStock = variaciones.some((v: any) => (v.StockActual ?? 0) > 0);

        if (hasVariantes && !selectedVarianteId) {
            if (algunaVarianteConStock) {
                alert('Selecciona una opción');
                return;
            }
            if (selectedProduct.StockActual <= 0) {
                alert('Producto agotado');
                return;
            }
            currentStock = selectedProduct.StockActual;
        }

        const qty = parseInt((document.getElementById('modal-qty') as HTMLInputElement).value);

        const basePrice = Number(selectedProduct.PrecioDetal) || 0;
        let baseWithVariante = basePrice;
        if (selectedVarianteId && selectedProduct.Variaciones?.length) {
            const varianteMatch = selectedProduct.Variaciones.find((v: any) => v.Id === selectedVarianteId);
            const adicional = varianteMatch?.PrecioAdicional ?? selectedVariantePrecioAdicional ?? 0;
            baseWithVariante = basePrice + (Number(adicional) || 0);
        }

        const promoItems = await applyPromotionsForItems([
            {
                productoId: selectedProduct.Id,
                varianteId: selectedVarianteId ?? null,
                cantidad: qty,
                precioBase: baseWithVariante,
            },
        ]);

        const unitPrice = promoItems[0]?.precioFinal ?? baseWithVariante;

        const item = {
            id: selectedProduct.Id,
            nombre: selectedProduct.Nombre,
            precio: unitPrice,
            imagen: selectedProduct.Imagenes?.[0]?.Url || '',
            varianteId: selectedVarianteId || null,
            varianteLabel: (window as any).varianteLabel || '',
            stockMax: currentStock,
            cantidad: qty
        };
        const idx = cart.findIndex(i => i.id === item.id && i.varianteId === item.varianteId);
        if (idx > -1) cart[idx].cantidad = Math.min(cart[idx].cantidad + qty, currentStock);
        else cart.push(item);
        updateCartUI(); toggleModal(false); toggleCart(true);
    };

    btnCheckout?.addEventListener('click', () => { toggleCart(false); toggleCheckout(true); });
    btnCloseCheckout?.addEventListener('click', () => toggleCheckout(false));

    checkoutForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btnSubmit = document.getElementById('btnSubmitOrder') as HTMLButtonElement;
        const formData = new FormData(checkoutForm);
        const data = {
            tiendaSlug: TIENDA_SLUG,
            cliente: { cedula: formData.get('cedula'), nombre: formData.get('nombre'), celular: formData.get('celular'), ciudad: formData.get('ciudad'), direccion: formData.get('direccion') },
            carrito: cart.map(item => ({ productoId: item.id, varianteId: item.varianteId, cantidad: item.cantidad, precioUnitario: item.precio })),
            metodoPago: formData.get('metodoPago'),
            observacionGeneral: formData.get('observacion')
        };
        btnSubmit.disabled = true;
        btnSubmit.innerHTML = '<div class="loading-spinner border-white border-t-transparent w-5 h-5"></div>';
        try {
            const res = await fetch(`${API_BASE}/pedidos`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
            if (res.ok) { cart = []; localStorage.removeItem('cart'); updateCartUI(); toggleCheckout(false); successModalOverlay.classList.remove('hidden'); }
            else { const err = await res.json(); alert(err.message || 'Error al procesar el pedido'); btnSubmit.disabled = false; btnSubmit.innerHTML = '<span>Confirmar Mi Pedido</span><i class="bi bi-arrow-right"></i>'; }
        } catch (error) { alert('Error de conexión'); btnSubmit.disabled = false; btnSubmit.innerHTML = '<span>Confirmar Mi Pedido</span><i class="bi bi-arrow-right"></i>'; }
    });

    document.addEventListener('click', (e) => { const card = (e.target as HTMLElement).closest('.product-card'); if (card) openProductModal(card.getAttribute('data-id')); });
    document.querySelectorAll('#btnOpenCart, .btnOpenCart').forEach(b => b.addEventListener('click', () => toggleCart(true)));
    document.getElementById('btnCloseCart').addEventListener('click', () => toggleCart(false));
    cartOverlay.addEventListener('click', () => toggleCart(false));
    document.getElementById('btnCloseModal').addEventListener('click', () => toggleModal(false));
    modalOverlay.addEventListener('click', (e) => { if (e.target === modalOverlay) toggleModal(false); });

    updateCartUI();
</script>

<style is:global>
    .loading-spinner { width: 30px; height: 30px; border: 3px solid #f3f3f3; border-top: 3px solid #000; border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
</style>
