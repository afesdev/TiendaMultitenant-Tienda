---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ProductCard from '../components/ProductCard.astro';
import Footer from '../components/Footer.astro';
import { SITE_CONFIG } from '../config';

const { API_BASE, TIENDA_SLUG } = SITE_CONFIG;

const { searchParams } = Astro.url;
const categoriaSlug = searchParams.get('categoria');
const buscar = searchParams.get('buscar');

let tiendaInfo = { NombreComercial: 'Cargando...' };
let categorias = [];
let productos = [];
let error = null;

try {
    const [tiendaRes, catRes] = await Promise.all([
        fetch(`${API_BASE}/tiendas/${TIENDA_SLUG}`),
        fetch(`${API_BASE}/tiendas/${TIENDA_SLUG}/categorias`)
    ]);

    if (tiendaRes.ok) {
        tiendaInfo = await tiendaRes.json();
    } else {
        error = `Tienda '${TIENDA_SLUG}' no encontrada.`;
    }

    if (catRes.ok) {
        categorias = await catRes.json();
    }

    if (!error) {
        let prodUrl = `${API_BASE}/tiendas/${TIENDA_SLUG}/productos`;
        const params = new URLSearchParams();
        
        // Priorizar filtros: Si hay búsqueda, se busca. Si hay categoría, se filtra.
        if (buscar) {
            params.append('buscar', buscar);
        } else if (categoriaSlug) {
            params.append('categoria', categoriaSlug);
        }
        
        if (params.toString()) prodUrl += `?${params.toString()}`;
        
        const prodRes = await fetch(prodUrl);
        if (prodRes.ok) {
            productos = await prodRes.json();
        }
    }
} catch (e) {
    error = "Error de conexión con el servidor.";
}
---

<Layout title={`${tiendaInfo.NombreComercial} - Tienda Online`}>
	<Navbar tiendaNombre={tiendaInfo.NombreComercial} categorias={categorias} />
	
	<main class="w-full flex-grow pb-32 lg:pb-12">
        {error && (
            <div class="container mx-auto px-4 py-20 text-center">
                <div class="bg-red-50 text-red-600 p-8 rounded-3xl border border-red-100 max-w-lg mx-auto">
                    <i class="bi bi-exclamation-circle text-4xl mb-4 block"></i>
                    <p class="font-bold uppercase tracking-widest text-xs">{error}</p>
                </div>
            </div>
        )}
        
        {!error && productos.length === 0 && (
            <div class="container mx-auto px-4 py-32 text-center">
                <div class="max-w-md mx-auto opacity-40">
                    <i class="bi bi-bag-x text-7xl mb-6 block text-gray-300"></i>
                    <h2 class="text-xs font-black uppercase tracking-[4px] text-gray-900 mb-2">Sin existencias</h2>
                    <p class="text-[11px] font-bold text-gray-400 uppercase tracking-widest leading-loose">
                        {buscar ? `No encontramos resultados para "${buscar}"` : (categoriaSlug ? 'No hay productos disponibles en esta categoría por el momento' : 'Nuestra colección se está renovando')}
                    </p>
                    <div class="mt-10">
                        <a href="/" class="inline-block px-8 py-4 bg-gray-900 text-white text-[10px] font-black uppercase tracking-[3px] rounded-2xl hover:bg-black transition-all shadow-xl shadow-gray-200">
                            Ver toda la tienda
                        </a>
                    </div>
                </div>
            </div>
        )}

        <!-- No results (búsqueda client-side) -->
        <div id="client-no-results" class="hidden container mx-auto px-4 py-32 text-center">
            <div class="max-w-md mx-auto opacity-40">
                <i class="bi bi-bag-x text-7xl mb-6 block text-gray-300"></i>
                <h2 class="text-xs font-black uppercase tracking-[4px] text-gray-900 mb-2">Sin resultados</h2>
                <p class="text-[11px] font-bold text-gray-400 uppercase tracking-widest leading-loose">
                    No encontramos resultados para "<span id="no-results-term"></span>"
                </p>
                <div class="mt-10">
                    <a href="/" class="inline-block px-8 py-4 bg-gray-900 text-white text-[10px] font-black uppercase tracking-[3px] rounded-2xl hover:bg-black transition-all shadow-xl shadow-gray-200">
                        Ver toda la tienda
                    </a>
                </div>
            </div>
        </div>

        <div class="px-px lg:px-6 w-full">
            <div id="products-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-px lg:gap-6 bg-gray-100 lg:bg-transparent">
                {productos.map((prod) => (
                    <ProductCard 
                        id={prod.Id}
                        nombre={prod.Nombre}
                        precio={prod.TieneOferta && prod.PrecioOferta != null ? prod.PrecioOferta : prod.PrecioDetal}
                        imagen={prod.ImagenPrincipal}
                        categoria={prod.CategoriaNombre}
                        descripcion={prod.Descripcion}
                        tallas={prod.Tallas}
                        colores={prod.Colores}
                        precioOriginal={prod.TieneOferta ? prod.PrecioDetal : undefined}
                        tieneOferta={prod.TieneOferta}
                    />
                ))}
            </div>
        </div>
	</main>

	<Footer tiendaInfo={tiendaInfo} />

    <!-- MODAL DE PRODUCTO (CENTRADO EN PC) -->
    <div id="productPanelOverlay" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[300] hidden opacity-0 transition-opacity duration-300"></div>
    <div id="productPanel" class="fixed inset-0 z-[301] flex items-center justify-center p-0 md:p-6 opacity-0 pointer-events-none translate-y-6 transition-all duration-300 ease-out">
        <div class="relative w-full h-full md:h-auto md:max-h-[calc(100vh-3rem)] md:max-w-5xl bg-white md:rounded-3xl overflow-hidden shadow-2xl">

            <!-- Botón cerrar -->
            <button id="btnClosePanel" class="absolute top-4 right-4 z-10 w-10 h-10 bg-black/25 hover:bg-black/50 backdrop-blur-sm rounded-full flex items-center justify-center transition-all">
                <i class="bi bi-x-lg text-sm text-white"></i>
            </button>

            <!-- Contenido scrollable -->
            <div id="panelContent" class="h-full md:max-h-[calc(100vh-3rem)] overflow-y-auto" style="-webkit-overflow-scrolling:touch">
                <div class="flex flex-col md:flex-row h-full">
                    <!-- Columna de imágenes -->
                    <div class="md:w-1/2 bg-gray-50">
                        <div class="relative w-full bg-gray-50 h-[280px] sm:h-[320px] md:h-[520px]">
                            <img id="panelMainImg" src="" alt="" class="w-full h-full object-contain md:object-cover" />
                            <button
                                type="button"
                                onclick="openPanelImageFullscreen()"
                                class="absolute bottom-4 right-4 z-10 w-9 h-9 bg-black/40 hover:bg-black/60 text-white rounded-full flex items-center justify-center text-xs shadow-md"
                                aria-label="Ampliar imagen"
                            >
                                <i class="bi bi-arrows-fullscreen"></i>
                            </button>
                        </div>
                        <div id="panelThumbs" class="hidden gap-2 overflow-x-auto px-4 py-3 bg-gray-50 border-t border-gray-100"></div>
                    </div>

                    <!-- Columna de detalle -->
                    <div class="md:w-1/2 px-6 py-6 flex flex-col gap-6">
                        <div class="flex items-start justify-between gap-4">
                            <h2 id="panelNombre" class="text-xl font-black text-gray-900 uppercase tracking-tighter leading-tight flex-1"></h2>
                            <span id="panelPrecio" class="text-xl font-black text-gray-900 tracking-tighter shrink-0"></span>
                        </div>

                        <p id="panelDescripcion" class="hidden text-xs text-gray-400 leading-relaxed"></p>

                        <div id="panelVariantes" class="hidden flex-col gap-2">
                            <span class="text-[9px] font-black uppercase tracking-[2px] text-gray-400">Selecciona una opción</span>
                            <div id="panelVariantesBtns" class="flex flex-wrap gap-2"></div>
                        </div>

                        <div class="flex items-center justify-between py-4 border-t border-b border-gray-100">
                            <div id="panelStock" class="text-[10px] font-bold uppercase tracking-widest text-green-500"></div>
                            <div class="flex items-center bg-gray-100 rounded-xl overflow-hidden">
                                <button onclick="updatePanelQty(-1)" class="w-10 h-10 font-black text-base hover:bg-gray-200 transition-colors">−</button>
                                <input type="number" id="panel-qty" value="1" class="w-10 bg-transparent text-center font-black text-sm outline-none" readonly />
                                <button onclick="updatePanelQty(1)" class="w-10 h-10 font-black text-base hover:bg-gray-200 transition-colors">+</button>
                            </div>
                        </div>

                        <button
                            id="panelBtnAdd"
                            onclick="addToCartFromPanel()"
                            class="w-full bg-gray-900 hover:bg-black text-white text-[11px] font-black uppercase tracking-[4px] py-5 rounded-2xl shadow-lg transition-all flex items-center justify-center gap-3"
                        >
                            <i class="bi bi-bag-plus text-sm"></i>
                            <span>Añadir a mi bolsa</span>
                        </button>

                        <div class="h-6"></div>
                    </div>
                </div>
            </div>

            <!-- Loading state -->
            <div id="panelLoading" class="hidden absolute inset-0 bg-white flex items-center justify-center">
                <div class="loading-spinner"></div>
            </div>
        </div>
    </div>

    <!-- OVERLAY IMAGEN AMPLIADA (PANEL PRODUCTO) -->
    <div id="panelImageFullscreenOverlay" class="fixed inset-0 bg-black/90 z-[700] hidden flex items-center justify-center p-4">
        <button id="btnClosePanelImageFullscreen" class="absolute top-6 right-6 w-10 h-10 rounded-full bg-black/60 hover:bg-black text-white flex items-center justify-center shadow-lg">
            <i class="bi bi-x-lg text-base"></i>
        </button>
        <img
            id="panelImageFullscreenImg"
            src=""
            alt="Vista ampliada del producto"
            class="max-h-full max-w-full object-contain rounded-2xl shadow-2xl"
        />
    </div>

    <!-- CARRITO LATERAL -->
    <div id="cartOverlay" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-[400] hidden transition-opacity duration-300 opacity-0"></div>
    <div id="cartOffcanvas" class="fixed top-0 right-0 h-full w-full max-w-[450px] bg-white z-[401] translate-x-full transition-transform duration-300 ease-in-out shadow-2xl flex flex-col">
        <div class="px-8 py-8 border-b border-gray-50 flex items-center justify-between bg-white">
            <h5 class="font-black text-xs uppercase tracking-[4px]">Mi Bolsa</h5>
            <button id="btnCloseCart" class="p-2 text-gray-400 hover:text-gray-900 transition-colors">
                <i class="bi bi-x-lg text-lg"></i>
            </button>
        </div>
        <div id="cartItems" class="flex-grow overflow-y-auto px-6 py-6 bg-gray-50/30">
            <!-- Items -->
        </div>
        <div id="cartFooter" class="p-8 bg-white border-t border-gray-100 hidden">
            <div class="flex justify-between items-center mb-8">
                <div class="flex flex-col">
                    <span class="text-[10px] font-black uppercase tracking-[3px] text-gray-400">Total Bolsa</span>
                    <span id="cart-item-count" class="text-[9px] font-bold text-primario uppercase">0 productos</span>
                </div>
                <span id="cartTotal" class="text-2xl font-black text-gray-900 tracking-tighter">$0</span>
            </div>
            <button id="btnCheckout" class="w-full bg-gray-900 hover:bg-black text-white text-[11px] font-black uppercase tracking-[4px] py-6 rounded-[2rem] shadow-xl transition-all">
                Finalizar Pedido
            </button>
        </div>
    </div>

    <!-- MODAL DE CHECKOUT -->
    <div id="checkoutModalOverlay" class="fixed inset-0 bg-black/60 backdrop-blur-md z-[500] hidden flex items-center justify-center p-4 transition-opacity duration-300 opacity-0">
        <div id="checkoutModal" class="bg-white w-full max-w-xl rounded-[2.5rem] overflow-hidden shadow-2xl relative translate-y-10 transition-transform duration-300">
            <div class="p-8 lg:p-12">
                <div class="flex justify-between items-center mb-8">
                    <h2 class="text-2xl font-black text-gray-900 uppercase tracking-tighter">Datos de Envío</h2>
                    <button id="btnCloseCheckout" class="text-gray-400 hover:text-gray-900"><i class="bi bi-x-lg text-xl"></i></button>
                </div>
                
                <form id="checkoutForm" class="space-y-4">
                    <div class="grid grid-cols-2 gap-4">
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[10px] font-black uppercase tracking-widest text-gray-400 ml-2">Cédula</label>
                            <input type="text" name="cedula" required class="bg-gray-50 border-0 rounded-2xl py-4 px-6 text-xs font-bold focus:ring-2 focus:ring-primario/20 outline-none" placeholder="123456789" />
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[10px] font-black uppercase tracking-widest text-gray-400 ml-2">WhatsApp</label>
                            <input type="tel" name="celular" required class="bg-gray-50 border-0 rounded-2xl py-4 px-6 text-xs font-bold focus:ring-2 focus:ring-primario/20 outline-none" placeholder="300 123 4567" />
                        </div>
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label class="text-[10px] font-black uppercase tracking-widest text-gray-400 ml-2">Nombre Completo</label>
                        <input type="text" name="nombre" required class="bg-gray-50 border-0 rounded-2xl py-4 px-6 text-xs font-bold focus:ring-2 focus:ring-primario/20 outline-none" placeholder="Ej: Juan Pérez" />
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[10px] font-black uppercase tracking-widest text-gray-400 ml-2">Ciudad</label>
                            <input type="text" name="ciudad" required class="bg-gray-50 border-0 rounded-2xl py-4 px-6 text-xs font-bold focus:ring-2 focus:ring-primario/20 outline-none" placeholder="Ej: Medellín" />
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[10px] font-black uppercase tracking-widest text-gray-400 ml-2">Método de Pago</label>
                            <select name="metodoPago" required class="bg-gray-50 border-0 rounded-2xl py-4 px-6 text-xs font-bold focus:ring-2 focus:ring-primario/20 outline-none appearance-none cursor-pointer">
                                <option value="Efectivo">Efectivo (Contra entrega)</option>
                                <option value="Transferencia">Transferencia Bancaria</option>
                            </select>
                        </div>
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label class="text-[10px] font-black uppercase tracking-widest text-gray-400 ml-2">Dirección Completa</label>
                        <input type="text" name="direccion" required class="bg-gray-50 border-0 rounded-2xl py-4 px-6 text-xs font-bold focus:ring-2 focus:ring-primario/20 outline-none" placeholder="Calle 123 #45-67 Barrio ..." />
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label class="text-[10px] font-black uppercase tracking-widest text-gray-400 ml-2">Observación (Opcional)</label>
                        <textarea name="observacion" class="bg-gray-50 border-0 rounded-2xl py-4 px-6 text-xs font-bold focus:ring-2 focus:ring-primario/20 outline-none resize-none" rows="2" placeholder="Ej: Portería, dejar con el vecino..."></textarea>
                    </div>

                    <button type="submit" id="btnSubmitOrder" class="w-full bg-gray-900 hover:bg-black text-white text-[11px] font-black uppercase tracking-[4px] py-6 rounded-[2rem] shadow-xl transition-all mt-4 flex items-center justify-center gap-3">
                        <span>Confirmar Mi Pedido</span>
                        <i class="bi bi-arrow-right"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- MODAL ÉXITO -->
    <div id="successModalOverlay" class="fixed inset-0 bg-white z-[600] hidden flex items-center justify-center p-4">
        <div class="text-center max-w-md mx-auto">
            <div class="w-24 h-24 bg-green-50 text-green-500 rounded-full flex items-center justify-center mx-auto mb-8 shadow-inner">
                <i class="bi bi-check-lg text-5xl"></i>
            </div>
            <h2 class="text-4xl font-black text-gray-900 uppercase tracking-tighter mb-4">¡Pedido Recibido!</h2>
            <p class="text-[11px] font-bold text-gray-400 uppercase tracking-widest leading-loose mb-10">Gracias por tu compra. Nos pondremos en contacto contigo vía WhatsApp para coordinar la entrega.</p>
            <button onclick="location.reload()" class="bg-gray-900 text-white text-[10px] font-black uppercase tracking-[3px] px-12 py-5 rounded-2xl hover:bg-black transition-all shadow-xl">
                Volver a la Tienda
            </button>
        </div>
    </div>
</Layout>

<script>
    import { SITE_CONFIG } from '../config';
    const { API_BASE, TIENDA_SLUG } = SITE_CONFIG;

    const fmtPrice = (p: number) => new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(p);

    function makeProductCard(prod: any) {
        const tallas = prod.Tallas ? prod.Tallas.split(',').filter(Boolean) : [];
        const colores = prod.Colores ? prod.Colores.split(',').filter(Boolean) : [];
        const img = prod.ImagenPrincipal || 'https://via.placeholder.com/600x900?text=Sin+Imagen';
        const precioMostrar = prod.TieneOferta && prod.PrecioOferta != null ? prod.PrecioOferta : prod.PrecioDetal;
        const precioHtml = prod.TieneOferta && prod.PrecioDetal != null
            ? `<span class="line-through text-gray-400 font-semibold mr-2">${fmtPrice(prod.PrecioDetal)}</span><span class="text-primario">${fmtPrice(precioMostrar)}</span>`
            : fmtPrice(precioMostrar);
        return `
            <div class="product-card group relative flex flex-col h-full bg-white transition-all cursor-pointer border border-gray-50 hover:shadow-2xl" data-id="${prod.Id}">
                <div class="relative overflow-hidden bg-gray-50 aspect-[2/3]">
                    <img src="${img}" alt="${prod.Nombre}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                    ${prod.CategoriaNombre ? `<span class="absolute top-3 left-3 bg-white/95 backdrop-blur-md text-gray-900 text-[9px] font-bold uppercase tracking-[2px] px-3 py-1.5 rounded shadow-sm">${prod.CategoriaNombre}</span>` : ''}
                    <div class="absolute inset-x-0 bottom-0 p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
                        <button class="w-full bg-gray-900/90 backdrop-blur text-white text-[10px] font-black uppercase tracking-[2px] py-3 rounded-xl shadow-lg">Ver Opciones</button>
                    </div>
                </div>
                <div class="p-5 lg:p-8 flex flex-col flex-grow text-center">
                    <h3 class="text-sm lg:text-base font-bold text-gray-900 uppercase tracking-widest mb-2 line-clamp-1 group-hover:text-primario transition-colors">${prod.Nombre}</h3>
                    <div class="mt-auto">
                        <p class="text-lg lg:text-xl font-black text-gray-900 mb-4">${precioHtml}</p>
                        <div class="flex flex-col gap-3 border-t border-gray-100 pt-5">
                            ${colores.length > 0 ? `<div class="flex flex-wrap gap-1.5 justify-center items-center">${colores.map((c: string) => `<div class="flex flex-col items-center gap-1"><span class="text-[8px] font-bold text-gray-400 uppercase tracking-tighter line-clamp-1 max-w-[50px]">${c.trim()}</span><div class="w-3 h-3 rounded-full border border-gray-200 bg-gray-100 shadow-inner"></div></div>`).join('')}</div>` : ''}
                            ${tallas.length > 0 ? `<div class="flex flex-wrap gap-1 justify-center">${tallas.map((t: string) => `<span class="text-[9px] font-bold text-gray-400 bg-gray-50 border border-gray-100 px-1.5 py-0.5 rounded uppercase">${t.trim()}</span>`).join('')}</div>` : ''}
                        </div>
                    </div>
                </div>
            </div>`;
    }

    async function runClientSearch(term: string) {
        const grid = document.getElementById('products-grid');
        const noResults = document.getElementById('client-no-results');
        const termSpan = document.getElementById('no-results-term');
        if (!grid) return;

        grid.innerHTML = `<div class="col-span-full flex items-center justify-center py-32"><div class="loading-spinner"></div></div>`;
        if (noResults) noResults.classList.add('hidden');

        try {
            const res = await fetch(`${API_BASE}/tiendas/${TIENDA_SLUG}/productos?buscar=${encodeURIComponent(term)}`);
            const products: any[] = res.ok ? await res.json() : [];

            if (products.length === 0) {
                grid.innerHTML = '';
                if (noResults) {
                    if (termSpan) termSpan.textContent = term;
                    noResults.classList.remove('hidden');
                }
            } else {
                if (noResults) noResults.classList.add('hidden');
                grid.innerHTML = products.map(makeProductCard).join('');
            }
        } catch {
            grid.innerHTML = '';
        }
    }

    const buscarParam = new URLSearchParams(window.location.search).get('buscar');
    if (buscarParam) runClientSearch(buscarParam);

    let cart = JSON.parse(localStorage.getItem('cart') || '[]');
    let selectedProduct = null;
    let selectedVarianteId = null;
    let selectedVariantePrecioAdicional = 0;
    let currentStock = 0;

    // Panel lateral de producto
    const panelOverlay  = document.getElementById('productPanelOverlay');
    const panel         = document.getElementById('productPanel');
    const panelContent  = document.getElementById('panelContent');
    const panelLoading  = document.getElementById('panelLoading');
    const btnClosePanel = document.getElementById('btnClosePanel');
    const panelImageFullscreenOverlay = document.getElementById('panelImageFullscreenOverlay');
    const btnClosePanelImageFullscreen = document.getElementById('btnClosePanelImageFullscreen');

    // Carrito
    const cartOverlay        = document.getElementById('cartOverlay');
    const cartOffcanvas      = document.getElementById('cartOffcanvas');
    const cartItemsContainer = document.getElementById('cartItems');
    const cartFooter         = document.getElementById('cartFooter');
    const cartTotal          = document.getElementById('cartTotal');
    const cartItemCount      = document.getElementById('cart-item-count');
    const btnCloseCart       = document.getElementById('btnCloseCart');

    let _scrollY = 0;
    const lockBody = () => {
        _scrollY = window.scrollY;
        document.body.style.position = 'fixed';
        document.body.style.top = `-${_scrollY}px`;
        document.body.style.width = '100%';
    };
    const unlockBody = () => {
        document.body.style.position = '';
        document.body.style.top = '';
        document.body.style.width = '';
        window.scrollTo(0, _scrollY);
    };

    const togglePanel = (show) => {
        if (show) {
            lockBody();
            panelContent.scrollTop = 0;
            panelOverlay.classList.remove('hidden');
            setTimeout(() => {
                panelOverlay.classList.add('opacity-100');
                panel.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-6');
                panel.classList.add('opacity-100', 'translate-y-0');
            }, 10);
        } else {
            panelOverlay.classList.remove('opacity-100');
            panel.classList.remove('opacity-100', 'translate-y-0');
            panel.classList.add('opacity-0', 'pointer-events-none', 'translate-y-6');
            setTimeout(() => {
                panelOverlay.classList.add('hidden');
                panelImageFullscreenOverlay?.classList.add('hidden');
                unlockBody();
            }, 300);
        }
    };

    const closePanelImageFullscreen = () => {
        panelImageFullscreenOverlay?.classList.add('hidden');
    };

    (window as any).openPanelImageFullscreen = () => {
        const mainImg = document.getElementById('panelMainImg') as HTMLImageElement | null;
        const fullscreenImg = document.getElementById('panelImageFullscreenImg') as HTMLImageElement | null;
        if (!mainImg || !fullscreenImg || !panelImageFullscreenOverlay) return;
        if (!mainImg.src) return;
        fullscreenImg.src = mainImg.src;
        panelImageFullscreenOverlay.classList.remove('hidden');
    };

    btnClosePanelImageFullscreen?.addEventListener('click', closePanelImageFullscreen);
    panelImageFullscreenOverlay?.addEventListener('click', (e) => {
        if (e.target === panelImageFullscreenOverlay) closePanelImageFullscreen();
    });

    const toggleCart = (show) => {
        if (show) {
            lockBody();
            cartOverlay.classList.remove('hidden');
            setTimeout(() => { cartOverlay.classList.add('opacity-100'); cartOffcanvas.classList.remove('translate-x-full'); }, 10);
        } else {
            cartOverlay.classList.remove('opacity-100');
            cartOffcanvas.classList.add('translate-x-full');
            setTimeout(() => { cartOverlay.classList.add('hidden'); unlockBody(); }, 300);
        }
    };

    function updateCartUI() {
        localStorage.setItem('cart', JSON.stringify(cart));
        const totalItemsCount = cart.reduce((acc, item) => acc + item.cantidad, 0);
        document.querySelectorAll('.cart-badge-count').forEach(b => {
            b.textContent = totalItemsCount;
            b.classList.toggle('hidden', totalItemsCount === 0);
        });

        if (cart.length === 0) {
            cartItemsContainer.innerHTML = `<div class="h-full flex flex-col items-center justify-center opacity-20"><i class="bi bi-bag-x text-6xl mb-4"></i><p class="text-[10px] font-black uppercase tracking-[3px]">Tu bolsa está vacía</p></div>`;
            cartFooter.classList.add('hidden');
        } else {
            let total = 0;
            cartItemsContainer.innerHTML = cart.map((item, i) => {
                total += item.precio * item.cantidad;
                const isMax = item.cantidad >= item.stockMax;
                return `
                    <div class="flex gap-5 bg-white p-5 rounded-3xl mb-4 shadow-sm border border-gray-50 group">
                        <img src="${item.imagen}" class="w-20 h-28 object-cover rounded-2xl bg-gray-100" />
                        <div class="flex-grow py-1 flex flex-col">
                            <div class="flex justify-between">
                                <h4 class="text-[10px] font-black uppercase tracking-wider text-gray-900">${item.nombre}</h4>
                                <button onclick="removeFromCart(${i})" class="text-gray-300 hover:text-red-500 transition-colors"><i class="bi bi-trash3"></i></button>
                            </div>
                            <p class="text-[9px] font-bold text-gray-400 mt-1 uppercase tracking-widest">${item.varianteLabel || ''}</p>
                            <div class="mt-auto flex justify-between items-center">
                                <div class="flex flex-col gap-1">
                                    <div class="flex items-center bg-gray-50 rounded-xl p-1 border border-gray-100">
                                        <button onclick="updateQty(${i}, -1)" class="w-7 h-7 flex items-center justify-center font-bold hover:text-primario transition-colors">-</button>
                                        <span class="w-8 text-center text-[10px] font-black">${item.cantidad}</span>
                                        <button onclick="updateQty(${i}, 1)" class="w-7 h-7 flex items-center justify-center font-bold transition-colors ${isMax ? 'text-gray-200 cursor-not-allowed' : 'hover:text-primario'}" ${isMax ? 'disabled' : ''}>+</button>
                                    </div>
                                    ${isMax ? `<span class="text-[7px] text-red-400 font-bold uppercase tracking-tighter">Límite de stock</span>` : ''}
                                </div>
                                <span class="text-xs font-black text-gray-900">${new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(item.precio * item.cantidad)}</span>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');
            cartTotal.textContent = new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(total);
            cartItemCount.textContent = `${totalItemsCount} ${totalItemsCount === 1 ? 'producto' : 'productos'}`;
            cartFooter.classList.remove('hidden');
        }
    }

    (window as any).removeFromCart = (i) => { cart.splice(i, 1); updateCartUI(); };
    (window as any).updateQty = (i, d) => { 
        const item = cart[i];
        const nextQty = item.cantidad + d;
        if (nextQty >= 1 && nextQty <= item.stockMax) { item.cantidad = nextQty; updateCartUI(); }
    };

    const fmt = (p) => new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(p);

    async function openProductPanel(id) {
        togglePanel(true);
        panelLoading.classList.remove('hidden');
        try {
            const res = await fetch(`${API_BASE}/productos/${id}`);
            const prod = await res.json();
            selectedProduct = prod;
            selectedVarianteId = null;
            currentStock = prod.StockActual;
            populatePanel(prod);
        } catch {
            panelLoading.classList.add('hidden');
        }
    }

    function populatePanel(prod) {
        const imagenes  = prod.Imagenes || [];
        const mainUrl   = imagenes[0]?.Url || 'https://via.placeholder.com/600x900?text=Sin+Imagen';
        const variaciones = prod.Variaciones || [];

        // Imagen principal
        const mainImg = document.getElementById('panelMainImg') as HTMLImageElement;
        mainImg.src = mainUrl;
        mainImg.alt = prod.Nombre;

        // Miniaturas
        const thumbsEl = document.getElementById('panelThumbs');
        if (imagenes.length > 1) {
            thumbsEl.innerHTML = imagenes.map((img, i) => `
                <img src="${img.Url}" onclick="selectPanelImage(this,'${img.Url}')"
                    class="w-14 h-20 shrink-0 object-cover rounded-xl cursor-pointer border-2 transition-all ${i === 0 ? 'border-gray-900 opacity-100' : 'border-transparent opacity-40 hover:opacity-70'}" />
            `).join('');
            thumbsEl.classList.remove('hidden');
            thumbsEl.classList.add('flex');
        } else {
            thumbsEl.classList.add('hidden');
            thumbsEl.classList.remove('flex');
        }

        // Nombre y precio (precio base o con oferta)
        (document.getElementById('panelNombre') as HTMLElement).textContent = prod.Nombre;
        const precioEl = document.getElementById('panelPrecio') as HTMLElement;
        const precioMostrar = prod.TieneOferta && prod.PrecioOferta != null ? prod.PrecioOferta : prod.PrecioDetal;
        if (prod.TieneOferta && prod.PrecioDetal != null) {
            precioEl.innerHTML = `<span class="line-through text-gray-400 font-semibold mr-2">${fmt(prod.PrecioDetal)}</span><span class="text-primario">${fmt(precioMostrar)}</span>`;
        } else {
            precioEl.textContent = fmt(precioMostrar);
        }
        selectedVariantePrecioAdicional = 0;

        // Descripción
        const descEl = document.getElementById('panelDescripcion');
        if (prod.Descripcion) {
            descEl.textContent = prod.Descripcion;
            descEl.classList.remove('hidden');
        } else {
            descEl.classList.add('hidden');
        }

        // Variantes
        const varsEl    = document.getElementById('panelVariantes');
        const varsBtns  = document.getElementById('panelVariantesBtns');
        if (variaciones.length > 0) {
            varsBtns.innerHTML = variaciones.map(v => {
                const precioBaseVar = (prod.PrecioDetal || 0) + (v.PrecioAdicional ?? 0);
                const precioOfertaVar = v.TieneOferta && v.PrecioOferta != null ? v.PrecioOferta : precioBaseVar;
                return `
                <button
                    onclick="selectPanelVariant(${v.Id},${v.StockActual},'${(v.Atributo || '')}: ${(v.Valor || '').replace(/'/g, "\\'")}',this)"
                    class="px-4 py-2 border border-gray-200 rounded-xl text-[10px] font-black uppercase tracking-wide transition-all ${v.StockActual <= 0 ? 'opacity-30 cursor-not-allowed line-through' : 'hover:border-gray-900 hover:bg-gray-900 hover:text-white'}"
                    data-precio-adicional="${v.PrecioAdicional ?? 0}"
                    data-precio-oferta="${precioOfertaVar}"
                    data-precio-base="${precioBaseVar}"
                    data-tiene-oferta="${v.TieneOferta ? '1' : '0'}"
                >
                    ${v.Valor}
                    ${v.PrecioAdicional && v.PrecioAdicional !== 0
                        ? `<span class="ml-1 text-[9px] font-normal opacity-70">(+${fmt(v.PrecioAdicional)})</span>`
                        : ''
                    }
                </button>
            `}).join('');
            varsEl.classList.remove('hidden');
            varsEl.classList.add('flex');
        } else {
            varsEl.classList.add('hidden');
        }

        // Stock
        const stockEl = document.getElementById('panelStock');
        stockEl.textContent = prod.StockActual > 0 ? `${prod.StockActual} disponibles` : 'Agotado';
        stockEl.className = `text-[10px] font-bold uppercase tracking-widest ${prod.StockActual > 0 ? 'text-green-500' : 'text-red-400'}`;

        // Qty
        (document.getElementById('panel-qty') as HTMLInputElement).value = '1';

        // Botón agregar
        const btnAdd = document.getElementById('panelBtnAdd') as HTMLButtonElement;
        if (prod.StockActual <= 0) {
            btnAdd.disabled = true;
            btnAdd.innerHTML = 'Agotado';
            btnAdd.classList.add('opacity-50', 'cursor-not-allowed');
        } else {
            btnAdd.disabled = false;
            btnAdd.innerHTML = '<i class="bi bi-bag-plus text-sm"></i><span>Añadir a mi bolsa</span>';
            btnAdd.classList.remove('opacity-50', 'cursor-not-allowed');
        }

        panelLoading.classList.add('hidden');
    }

    (window as any).selectPanelImage = (thumb, url) => {
        const mainImg = document.getElementById('panelMainImg') as HTMLImageElement;
        mainImg.style.opacity = '0';
        setTimeout(() => { mainImg.src = url; mainImg.style.opacity = '1'; }, 150);
        thumb.parentElement.querySelectorAll('img').forEach(img => {
            img.classList.remove('border-gray-900', 'opacity-100');
            img.classList.add('border-transparent', 'opacity-40');
        });
        thumb.classList.remove('border-transparent', 'opacity-40');
        thumb.classList.add('border-gray-900', 'opacity-100');
    };

    (window as any).selectPanelVariant = (id, stock, label, btn) => {
        btn.parentElement.querySelectorAll('button').forEach(b => b.classList.remove('bg-gray-900', 'text-white', 'border-gray-900'));
        btn.classList.add('bg-gray-900', 'text-white', 'border-gray-900');
        selectedVarianteId = id;
        currentStock = stock;
        (window as any).varianteLabel = label;

        // Precio de la variante (oferta o base)
        const adicionalAttr = (btn as HTMLButtonElement).getAttribute('data-precio-adicional');
        selectedVariantePrecioAdicional = adicionalAttr ? Number(adicionalAttr) : 0;
        if (isNaN(selectedVariantePrecioAdicional)) selectedVariantePrecioAdicional = 0;

        const precioOfertaAttr = (btn as HTMLButtonElement).getAttribute('data-precio-oferta');
        const precioBaseAttr = (btn as HTMLButtonElement).getAttribute('data-precio-base');
        const tieneOfertaAttr = (btn as HTMLButtonElement).getAttribute('data-tiene-oferta');
        const precioMostrar = precioOfertaAttr ? Number(precioOfertaAttr) : (precioBaseAttr ? Number(precioBaseAttr) : 0);
        const precioBase = precioBaseAttr ? Number(precioBaseAttr) : 0;
        const tieneOferta = tieneOfertaAttr === '1';

        const precioEl = document.getElementById('panelPrecio') as HTMLElement | null;
        if (precioEl) {
            if (tieneOferta && precioBase > 0) {
                precioEl.innerHTML = `<span class="line-through text-gray-400 font-semibold mr-2">${fmt(precioBase)}</span><span class="text-primario">${fmt(precioMostrar)}</span>`;
            } else {
                precioEl.textContent = fmt(precioMostrar);
            }
        }

        const stockEl = document.getElementById('panelStock');
        stockEl.textContent = stock > 0 ? `${stock} disponibles` : 'Agotado';
        stockEl.className = `text-[10px] font-bold uppercase tracking-widest ${stock > 0 ? 'text-green-500' : 'text-red-500'}`;
        const btnAdd = document.getElementById('panelBtnAdd') as HTMLButtonElement;
        if (stock <= 0) {
            btnAdd.disabled = true;
            btnAdd.innerHTML = 'Agotado';
            btnAdd.classList.add('opacity-50', 'cursor-not-allowed');
        } else {
            btnAdd.disabled = false;
            btnAdd.innerHTML = '<i class="bi bi-bag-plus text-sm"></i><span>Añadir a mi bolsa</span>';
            btnAdd.classList.remove('opacity-50', 'cursor-not-allowed');
        }
        (document.getElementById('panel-qty') as HTMLInputElement).value = '1';
    };

    (window as any).updatePanelQty = (d) => {
        const input = document.getElementById('panel-qty') as HTMLInputElement;
        const next = parseInt(input.value) + d;
        if (next >= 1 && next <= currentStock) input.value = String(next);
    };

    async function applyPromotionsForItems(items: any[]) {
        try {
            const resp = await fetch(`${API_BASE}/promociones/calcular`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    tiendaSlug: TIENDA_SLUG,
                    items: items.map((it) => ({
                        productoId: it.productoId,
                        varianteId: it.varianteId ?? null,
                        cantidad: it.cantidad,
                        precioBase: it.precioBase,
                    })),
                }),
            });
            if (!resp.ok) return items;
            const data = await resp.json();
            return data.map((r: any, idx: number) => ({
                ...items[idx],
                precioFinal: typeof r.precioFinal === 'number' ? r.precioFinal : items[idx].precioBase,
            }));
        } catch {
            return items;
        }
    }

    (window as any).addToCartFromPanel = async () => {
        const variaciones = selectedProduct.Variaciones || [];
        const hasVariantes = variaciones.length > 0;
        const algunaVarianteConStock = variaciones.some((v: any) => (v.StockActual ?? 0) > 0);

        if (hasVariantes && !selectedVarianteId) {
            if (algunaVarianteConStock) {
                alert('Selecciona una opción');
                return;
            }
            if (selectedProduct.StockActual <= 0) {
                alert('Producto agotado');
                return;
            }
            currentStock = selectedProduct.StockActual;
        }

        const qty  = parseInt((document.getElementById('panel-qty') as HTMLInputElement).value);
        const basePrice = Number(selectedProduct.PrecioDetal) || 0;
        let baseWithVariante = basePrice;

        if (selectedVarianteId && selectedProduct.Variaciones?.length) {
            const varianteMatch = selectedProduct.Variaciones.find((v: any) => v.Id === selectedVarianteId);
            const adicional = varianteMatch?.PrecioAdicional ?? selectedVariantePrecioAdicional ?? 0;
            baseWithVariante = basePrice + (Number(adicional) || 0);
        }

        const promoItems = await applyPromotionsForItems([
            {
                productoId: selectedProduct.Id,
                varianteId: selectedVarianteId ?? null,
                cantidad: qty,
                precioBase: baseWithVariante,
            },
        ]);

        const unitPrice = promoItems[0]?.precioFinal ?? baseWithVariante;

        const item = {
            id: selectedProduct.Id,
            nombre: selectedProduct.Nombre,
            precio: unitPrice,
            imagen: selectedProduct.Imagenes?.[0]?.Url || '',
            varianteId: selectedVarianteId || null,
            varianteLabel: (window as any).varianteLabel || '',
            stockMax: currentStock,
            cantidad: qty
        };
        const idx = cart.findIndex(i => i.id === item.id && i.varianteId === item.varianteId);
        if (idx > -1) cart[idx].cantidad = Math.min(cart[idx].cantidad + qty, currentStock);
        else cart.push(item);
        updateCartUI();
        togglePanel(false);
        toggleCart(true);
    };

    document.addEventListener('click', (e) => {
        const card = (e.target as HTMLElement).closest('.product-card');
        if (card) openProductPanel(card.getAttribute('data-id'));
    });

    const btnCheckout = document.getElementById('btnCheckout');
    const checkoutModalOverlay = document.getElementById('checkoutModalOverlay');
    const checkoutModal = document.getElementById('checkoutModal');
    const btnCloseCheckout = document.getElementById('btnCloseCheckout');
    const checkoutForm = document.getElementById('checkoutForm') as HTMLFormElement;
    const successModalOverlay = document.getElementById('successModalOverlay');

    const toggleCheckout = (show) => {
        if (show) {
            checkoutModalOverlay.classList.remove('hidden');
            setTimeout(() => {
                checkoutModalOverlay.classList.add('opacity-100');
                checkoutModal.classList.add('translate-y-0');
            }, 10);
        } else {
            checkoutModalOverlay.classList.remove('opacity-100');
            checkoutModal.classList.remove('translate-y-0');
            setTimeout(() => checkoutModalOverlay.classList.add('hidden'), 300);
        }
    };

    btnCheckout?.addEventListener('click', () => {
        toggleCart(false);
        toggleCheckout(true);
    });

    btnCloseCheckout?.addEventListener('click', () => toggleCheckout(false));

    checkoutForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btnSubmit = document.getElementById('btnSubmitOrder') as HTMLButtonElement;
        const formData = new FormData(checkoutForm);
        
        const data = {
            tiendaSlug: TIENDA_SLUG,
            cliente: {
                cedula: formData.get('cedula'),
                nombre: formData.get('nombre'),
                celular: formData.get('celular'),
                ciudad: formData.get('ciudad'),
                direccion: formData.get('direccion')
            },
            carrito: cart.map(item => ({
                productoId: item.id,
                varianteId: item.varianteId,
                cantidad: item.cantidad,
                precioUnitario: item.precio
            })),
            metodoPago: formData.get('metodoPago'),
            observacionGeneral: formData.get('observacion')
        };

        btnSubmit.disabled = true;
        btnSubmit.innerHTML = '<div class="loading-spinner border-white border-t-transparent w-5 h-5"></div>';

        try {
            const res = await fetch(`${API_BASE}/pedidos`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            if (res.ok) {
                cart = [];
                localStorage.removeItem('cart');
                updateCartUI();
                toggleCheckout(false);
                successModalOverlay.classList.remove('hidden');
            } else {
                const err = await res.json();
                alert(err.message || 'Error al procesar el pedido');
                btnSubmit.disabled = false;
                btnSubmit.innerHTML = '<span>Confirmar Mi Pedido</span><i class="bi bi-arrow-right"></i>';
            }
        } catch (error) {
            alert('Error de conexión');
            btnSubmit.disabled = false;
            btnSubmit.innerHTML = '<span>Confirmar Mi Pedido</span><i class="bi bi-arrow-right"></i>';
        }
    });

    document.querySelectorAll('#btnOpenCart, .btnOpenCart').forEach(b => b.addEventListener('click', () => toggleCart(true)));
    btnCloseCart.addEventListener('click', () => toggleCart(false));
    cartOverlay.addEventListener('click', () => toggleCart(false));
    btnClosePanel.addEventListener('click', () => togglePanel(false));
    panelOverlay.addEventListener('click', () => togglePanel(false));

    updateCartUI();
</script>

<style is:global>
    .loading-spinner { width: 30px; height: 30px; border: 3px solid #f3f3f3; border-top: 3px solid #000; border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    input::-webkit-outer-spin-button, input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
    input[type=number] { -moz-appearance: textfield; }
    #panelContent {
        -webkit-overflow-scrolling: touch;
    }
</style>
